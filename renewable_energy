<script>
// ===================== DATA ENGINE =====================
const DIESEL_KWH = 3.6; // kWh per litre diesel
const DIESEL_PRICE = 1.35; // $ per litre
const CO2_PER_KWH = 0.453; // kg CO2 per kWh (grid average)
const TOTAL_HOME_DAILY = 30; // kWh — average daily home usage

// Simulation state
let windmill = { base: 18, val: 18 };
let spindle  = { base: 12, val: 12 };
let solar    = { base: 14, val: 14 };

// Sparkline history arrays
let sparkW = [], sparkS = [], sparkSo = [];
const SPARK_MAX = 20;

// Clock
function updateClock() {
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
setInterval(updateClock, 1000);
updateClock();

// Smooth number counter
function animNum(id, target, decimals=1, suffix='') {
  const el = document.getElementById(id);
  const start = parseFloat(el.textContent) || 0;
  const duration = 600;
  const startTime = performance.now();
  function step(now) {
    const progress = Math.min((now - startTime)/duration, 1);
    const ease = 1 - Math.pow(1-progress,3);
    const val = start + (target-start)*ease;
    el.textContent = val.toFixed(decimals) + suffix;
    if(progress<1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

// Donut chart update
function updateDonut(w, s, so) {
  const total = w + s + so;
  const circ = 2 * Math.PI * 60; // 376.99
  const wArc  = (w/total)*circ;
  const sArc  = (s/total)*circ;
  const soArc = (so/total)*circ;

  const arcW  = document.getElementById('arcWindmill');
  const arcS  = document.getElementById('arcSpindle');
  const arcSo = document.getElementById('arcSolar');

  arcW.setAttribute('stroke-dasharray', `${wArc} ${circ-wArc}`);
  arcW.setAttribute('stroke-dashoffset', `${circ*0.25}`);

  const sOffset = circ*0.25 - wArc;
  arcS.setAttribute('stroke-dasharray', `${sArc} ${circ-sArc}`);
  arcS.setAttribute('stroke-dashoffset', `${sOffset}`);

  const soOffset = sOffset - sArc;
  arcSo.setAttribute('stroke-dasharray', `${soArc} ${circ-soArc}`);
  arcSo.setAttribute('stroke-dashoffset', `${soOffset}`);

  document.getElementById('donutCenter').textContent = total.toFixed(1);
}

// Sparkline canvas draw
function drawSparkline(canvasId, data, color) {
  const canvas = document.getElementById(canvasId);
  const ctx = canvas.getContext('2d');
  const W = canvas.offsetWidth || canvas.width;
  const H = canvas.offsetHeight || 50;
  canvas.width = W; canvas.height = H;
  ctx.clearRect(0,0,W,H);
  if(data.length < 2) return;
  const min = Math.min(...data)*0.9;
  const max = Math.max(...data)*1.1;
  const range = max-min || 1;
  const step = W/(data.length-1);
  // Gradient fill
  const grad = ctx.createLinearGradient(0,0,0,H);
  grad.addColorStop(0, color+'44');
  grad.addColorStop(1, color+'00');
  ctx.beginPath();
  ctx.moveTo(0, H - ((data[0]-min)/range)*H);
  for(let i=1;i<data.length;i++) {
    ctx.lineTo(i*step, H - ((data[i]-min)/range)*H);
  }
  ctx.lineTo(W,H); ctx.lineTo(0,H); ctx.closePath();
  ctx.fillStyle = grad; ctx.fill();
  // Line
  ctx.beginPath();
  ctx.moveTo(0, H - ((data[0]-min)/range)*H);
  for(let i=1;i<data.length;i++) {
    ctx.lineTo(i*step, H - ((data[i]-min)/range)*H);
  }
  ctx.strokeStyle = color;
  ctx.lineWidth = 2;
  ctx.stroke();
  // Dot at end
  ctx.beginPath();
  ctx.arc(W, H - ((data[data.length-1]-min)/range)*H, 3, 0, Math.PI*2);
  ctx.fillStyle = color; ctx.fill();
}

// VS Chart bars
function updateVsBars(renewable, conventional, pctSaved) {
  const maxVal = Math.max(renewable, conventional, 1);
  const h = 120; // max bar height px
  document.getElementById('vsRenewBar').style.height = (renewable/maxVal*h)+'px';
  document.getElementById('vsConvBar').style.height  = (conventional/maxVal*h)+'px';
  document.getElementById('vsSaveBar').style.height  = (pctSaved/100*h)+'px';
  document.getElementById('vsRenewVal').textContent  = renewable.toFixed(1)+' kWh';
  document.getElementById('vsConvVal').textContent   = conventional.toFixed(1)+' kWh';
  document.getElementById('vsSaveVal').textContent   = pctSaved.toFixed(0)+'%';
}

// Badge logic
function updateBadges(w, s, so) {
  const max = Math.max(w, s, so);
  document.getElementById('windmillBadge').style.display = (w===max)?'inline-flex':'none';
  document.getElementById('spindleBadge').style.display  = (s===max)?'inline-flex':'none';
  document.getElementById('solarBadge').style.display    = (so===max)?'inline-flex':'none';

  const topName = w===max?'Windmill 🌬️': s===max?'Wind Spindle 💨':'Solar Panels ☀️';
  const topPct  = (max/(w+s+so)*100).toFixed(0)+'% of output';
  document.getElementById('topProducer').textContent = topName;
  document.getElementById('topPct').textContent = topPct;
}

// Main update function
function update() {
  // Drift values with noise
  const hour = new Date().getHours();
  const solarFactor = hour>=6&&hour<=19 ? Math.sin((hour-6)/13*Math.PI) : 0.02;
  
  windmill.val = Math.max(2, windmill.base + (Math.random()-0.48)*3);
  spindle.val  = Math.max(1, spindle.base  + (Math.random()-0.48)*2);
  solar.val    = Math.max(0.1, solar.base * solarFactor + (Math.random()-0.5)*1.5);

  // Accumulate "today" (simulate as running total * time_fraction_of_day)
  const tod = (new Date().getHours()*60+new Date().getMinutes())/(24*60);
  const wDay  = windmill.val * 24 * tod;
  const sDay  = spindle.val  * 24 * tod;
  const soDay = solar.val    * 24 * tod;
  const total = wDay + sDay + soDay;

  const wPct  = (wDay/total*100);
  const sPct  = (sDay/total*100);
  const soPct = (soDay/total*100);

  // Bars
  const maxKwh = Math.max(wDay,sDay,soDay);
  document.getElementById('windmillBar').style.width = (wDay/maxKwh*100)+'%';
  document.getElementById('spindleBar').style.width  = (sDay/maxKwh*100)+'%';
  document.getElementById('solarBar').style.width    = (soDay/maxKwh*100)+'%';

  document.getElementById('windmillKwh').textContent = wDay.toFixed(1)+' kWh';
  document.getElementById('spindleKwh').textContent  = sDay.toFixed(1)+' kWh';
  document.getElementById('solarKwh').textContent    = soDay.toFixed(1)+' kWh';

  document.getElementById('windmillPct').textContent = wPct.toFixed(1)+'% of total';
  document.getElementById('spindlePct').textContent  = sPct.toFixed(1)+'% of total';
  document.getElementById('solarPct').textContent    = soPct.toFixed(1)+'% of total';

  // Donut
  updateDonut(wDay, sDay, soDay);
  document.getElementById('lgWindmill').textContent = wDay.toFixed(1)+' kWh';
  document.getElementById('lgSpindle').textContent  = sDay.toFixed(1)+' kWh';
  document.getElementById('lgSolar').textContent    = soDay.toFixed(1)+' kWh';

  // Top stats
  document.getElementById('totalKwh').innerHTML = total.toFixed(1)+'<span class="stat-unit">kWh</span>';
  updateBadges(wDay, sDay, soDay);

  // Fuel saved (1 kWh = 1/3.6 litres diesel avoided)
  const totalFuel = total / DIESEL_KWH;
  const wFuel  = wDay/DIESEL_KWH;
  const sFuel  = sDay/DIESEL_KWH;
  const soFuel = soDay/DIESEL_KWH;

  document.getElementById('fuelLitres').textContent = totalFuel.toFixed(1);
  document.getElementById('fuelSavedTop').innerHTML = totalFuel.toFixed(1)+'<span class="stat-unit">L</span>';
  document.getElementById('fuelWindmill').textContent = wFuel.toFixed(1)+' L';
  document.getElementById('fuelSpindle').textContent  = sFuel.toFixed(1)+' L';
  document.getElementById('fuelSolar').textContent    = soFuel.toFixed(1)+' L';
  const moneySaved = totalFuel * DIESEL_PRICE;
  document.getElementById('moneySaved').textContent = '$'+moneySaved.toFixed(2);

  // CO2
  const co2 = total * CO2_PER_KWH;
  document.getElementById('co2Avoided').innerHTML = co2.toFixed(1)+'<span class="stat-unit">kg</span>';
  document.getElementById('co2Total').textContent = co2.toFixed(1)+' kg';

  // VS Chart
  const conventional = TOTAL_HOME_DAILY * tod * 1.3; // what would have been needed from grid
  const pctSaved = Math.min(99,(total/conventional)*100);
  updateVsBars(total, conventional, pctSaved);

  // Real-time values
  document.getElementById('rtWindmill').textContent = windmill.val.toFixed(2)+' kW';
  document.getElementById('rtSpindle').textContent  = spindle.val.toFixed(2)+' kW';
  document.getElementById('rtSolar').textContent    = solar.val.toFixed(2)+' kW';

  // Sparklines
  sparkW.push(windmill.val);  if(sparkW.length>SPARK_MAX)  sparkW.shift();
  sparkS.push(spindle.val);   if(sparkS.length>SPARK_MAX)  sparkS.shift();
  sparkSo.push(solar.val);    if(sparkSo.length>SPARK_MAX) sparkSo.shift();

  drawSparkline('sparkWindmill', sparkW,  '#00cfff');
  drawSparkline('sparkSpindle',  sparkS,  '#00ff88');
  drawSparkline('sparkSolar',    sparkSo, '#ffe44d');

  // Recommendation coverage
  const coverage = Math.min(99, (total/TOTAL_HOME_DAILY)*100);
  document.getElementById('recCoverage').textContent = coverage.toFixed(0);
}

// Initial update + interval
update();
setInterval(update, 2000);

// Resize sparklines
window.addEventListener('resize', () => {
  drawSparkline('sparkWindmill', sparkW,  '#00cfff');
  drawSparkline('sparkSpindle',  sparkS,  '#00ff88');
  drawSparkline('sparkSolar',    sparkSo, '#ffe44d');
});
</script>
