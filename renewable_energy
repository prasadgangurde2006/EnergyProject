<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EcoGrid — Renewable Energy Monitor</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Space+Mono:wght@400;700&family=Exo+2:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #030d0a;
    --surface: #071a12;
    --card: #0b2318;
    --border: #0f3d22;
    --green: #00ff88;
    --green2: #00cc6a;
    --yellow: #ffe44d;
    --blue: #00cfff;
    --orange: #ff8c42;
    --red: #ff4566;
    --text: #c8f0dc;
    --muted: #4a8a6a;
    --glow: 0 0 20px rgba(0,255,136,0.3);
    --glow-strong: 0 0 40px rgba(0,255,136,0.5);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Exo 2', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Animated grid background */
  body::before {
    content:'';
    position:fixed;
    inset:0;
    background-image:
      linear-gradient(rgba(0,255,136,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,136,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events:none;
    z-index:0;
  }

  /* Floating orbs */
  .orb {
    position:fixed;
    border-radius:50%;
    filter:blur(80px);
    pointer-events:none;
    z-index:0;
    animation: floatOrb 12s ease-in-out infinite;
  }
  .orb1 { width:400px;height:400px;background:rgba(0,255,136,0.06);top:-100px;left:-100px; }
  .orb2 { width:300px;height:300px;background:rgba(0,207,255,0.05);bottom:10%;right:-50px;animation-delay:-6s; }
  .orb3 { width:250px;height:250px;background:rgba(255,228,77,0.04);top:50%;left:40%;animation-delay:-3s; }

  @keyframes floatOrb {
    0%,100%{transform:translate(0,0) scale(1);}
    50%{transform:translate(30px,20px) scale(1.1);}
  }

  /* Header */
  header {
    position:relative;
    z-index:10;
    padding: 20px 40px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    border-bottom: 1px solid var(--border);
    background: rgba(3,13,10,0.8);
    backdrop-filter:blur(10px);
  }

  .logo {
    font-family:'Orbitron',monospace;
    font-size:1.6rem;
    font-weight:900;
    color:var(--green);
    text-shadow: var(--glow);
    letter-spacing:4px;
  }
  .logo span { color: var(--text); }

  .live-badge {
    display:flex;
    align-items:center;
    gap:8px;
    font-family:'Space Mono',monospace;
    font-size:0.75rem;
    color:var(--green);
    letter-spacing:2px;
  }
  .live-dot {
    width:8px;height:8px;
    border-radius:50%;
    background:var(--green);
    animation: pulse 1.5s infinite;
    box-shadow: 0 0 8px var(--green);
  }
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

  .clock {
    font-family:'Space Mono',monospace;
    font-size:1.1rem;
    color:var(--green);
    text-shadow: var(--glow);
  }

  /* Main layout */
  .container {
    position:relative;
    z-index:1;
    max-width:1400px;
    margin:0 auto;
    padding:30px 20px;
  }

  /* Section title */
  .section-title {
    font-family:'Orbitron',monospace;
    font-size:0.7rem;
    letter-spacing:4px;
    color:var(--muted);
    text-transform:uppercase;
    margin-bottom:16px;
    display:flex;
    align-items:center;
    gap:10px;
  }
  .section-title::after {
    content:'';
    flex:1;
    height:1px;
    background: linear-gradient(90deg, var(--border), transparent);
  }

  /* ===== TOP STATS ROW ===== */
  .top-stats {
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    gap:16px;
    margin-bottom:30px;
  }

  .stat-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius:12px;
    padding:20px;
    position:relative;
    overflow:hidden;
    transition: border-color 0.3s, transform 0.3s;
  }
  .stat-card:hover {
    border-color:var(--green);
    transform:translateY(-2px);
    box-shadow: var(--glow);
  }
  .stat-card::before {
    content:'';
    position:absolute;
    top:0;left:0;right:0;
    height:2px;
    background: var(--accent, var(--green));
  }

  .stat-label {
    font-family:'Space Mono',monospace;
    font-size:0.65rem;
    letter-spacing:2px;
    color:var(--muted);
    text-transform:uppercase;
    margin-bottom:8px;
  }
  .stat-value {
    font-family:'Orbitron',monospace;
    font-size:2rem;
    font-weight:700;
    color:var(--accent, var(--green));
    line-height:1;
    text-shadow: 0 0 20px var(--accent, var(--green));
    transition: all 0.5s;
  }
  .stat-unit {
    font-size:0.8rem;
    font-weight:400;
    opacity:0.7;
    margin-left:4px;
  }
  .stat-sub {
    font-size:0.75rem;
    color:var(--muted);
    margin-top:6px;
  }
  .stat-icon {
    position:absolute;
    top:16px;right:16px;
    font-size:1.6rem;
    opacity:0.3;
  }

  /* ===== MAIN GRID ===== */
  .main-grid {
    display:grid;
    grid-template-columns: 2fr 1fr;
    gap:20px;
    margin-bottom:24px;
  }

  .card {
    background:var(--card);
    border:1px solid var(--border);
    border-radius:16px;
    padding:24px;
    position:relative;
    overflow:hidden;
  }
  .card-title {
    font-family:'Orbitron',monospace;
    font-size:0.8rem;
    letter-spacing:3px;
    color:var(--green);
    text-transform:uppercase;
    margin-bottom:20px;
  }

  /* ===== SOURCE BARS (Windmill / Wind Spindle / Solar) ===== */
  .source-list { display:flex;flex-direction:column;gap:18px; }

  .source-item { position:relative; }
  .source-header {
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-bottom:8px;
  }
  .source-name {
    display:flex;
    align-items:center;
    gap:10px;
    font-weight:600;
    font-size:0.95rem;
  }
  .source-icon { font-size:1.4rem; }
  .source-kwh {
    font-family:'Orbitron',monospace;
    font-size:1.1rem;
    font-weight:700;
  }

  .bar-track {
    height:10px;
    background:rgba(255,255,255,0.05);
    border-radius:10px;
    overflow:hidden;
    position:relative;
  }
  .bar-fill {
    height:100%;
    border-radius:10px;
    transition:width 1s cubic-bezier(0.4,0,0.2,1);
    position:relative;
  }
  .bar-fill::after {
    content:'';
    position:absolute;
    right:0;top:0;bottom:0;
    width:20px;
    background:rgba(255,255,255,0.4);
    filter:blur(4px);
    animation: shimmer 2s infinite;
  }
  @keyframes shimmer { 0%,100%{opacity:0.4;} 50%{opacity:1;} }

  .source-pct {
    font-size:0.75rem;
    color:var(--muted);
    margin-top:4px;
  }

  /* WINNER BADGE */
  .winner-badge {
    display:inline-flex;
    align-items:center;
    gap:6px;
    background:rgba(255,228,77,0.1);
    border:1px solid rgba(255,228,77,0.3);
    color:var(--yellow);
    font-size:0.65rem;
    font-family:'Space Mono',monospace;
    letter-spacing:2px;
    padding:3px 8px;
    border-radius:20px;
    text-transform:uppercase;
  }

  /* ===== DONUT CHART ===== */
  .donut-wrap {
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:20px;
  }
  .donut-svg { filter: drop-shadow(0 0 10px rgba(0,255,136,0.2)); }

  .donut-legend {
    display:flex;
    flex-direction:column;
    gap:10px;
    width:100%;
  }
  .legend-item {
    display:flex;
    align-items:center;
    gap:10px;
    font-size:0.85rem;
  }
  .legend-dot { width:10px;height:10px;border-radius:50%; flex-shrink:0; }
  .legend-label { flex:1;color:var(--muted); }
  .legend-val { font-family:'Orbitron',monospace;font-size:0.8rem; }

  /* ===== COMPARISON SECTION ===== */
  .compare-grid {
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:16px;
    margin-bottom:24px;
  }

  .compare-card {
    background:var(--card);
    border:1px solid var(--border);
    border-radius:16px;
    padding:20px;
    position:relative;
    overflow:hidden;
    transition: all 0.3s;
  }
  .compare-card:hover {
    transform:translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.4);
  }
  .compare-card.best {
    border-color:var(--yellow);
    box-shadow: 0 0 20px rgba(255,228,77,0.15);
  }
  .best-ribbon {
    position:absolute;
    top:12px;right:-1px;
    background:var(--yellow);
    color:#000;
    font-family:'Orbitron',monospace;
    font-size:0.55rem;
    font-weight:700;
    letter-spacing:1px;
    padding:4px 10px;
    border-radius:4px 0 0 4px;
  }

  .compare-icon { font-size:2.5rem;margin-bottom:10px; }
  .compare-name {
    font-family:'Orbitron',monospace;
    font-size:0.9rem;
    font-weight:700;
    color:var(--green);
    margin-bottom:14px;
    letter-spacing:2px;
  }

  .compare-row {
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:7px 0;
    border-bottom:1px solid rgba(255,255,255,0.04);
    font-size:0.8rem;
  }
  .compare-row:last-child { border-bottom:none; }
  .compare-key { color:var(--muted); }
  .compare-val { font-family:'Space Mono',monospace;font-size:0.78rem; }

  /* Score bar */
  .score-label {
    font-size:0.7rem;
    color:var(--muted);
    margin-top:14px;
    margin-bottom:6px;
    font-family:'Space Mono',monospace;
    letter-spacing:1px;
  }
  .score-bar {
    height:6px;
    background:rgba(255,255,255,0.05);
    border-radius:6px;
    overflow:hidden;
  }
  .score-fill {
    height:100%;
    border-radius:6px;
    transition:width 1.5s ease;
  }

  /* ===== FUEL SAVE & VS SECTION ===== */
  .bottom-grid {
    display:grid;
    grid-template-columns:1fr 1.5fr;
    gap:20px;
    margin-bottom:24px;
  }

  /* Fuel counter */
  .fuel-display {
    text-align:center;
    padding:10px 0;
  }
  .fuel-number {
    font-family:'Orbitron',monospace;
    font-size:3.5rem;
    font-weight:900;
    color:var(--orange);
    text-shadow: 0 0 30px var(--orange);
    line-height:1;
    transition: all 0.5s;
  }
  .fuel-unit {
    font-family:'Space Mono',monospace;
    font-size:0.9rem;
    color:var(--muted);
    letter-spacing:3px;
    margin-top:4px;
  }
  .fuel-sub {
    font-size:0.8rem;
    color:var(--muted);
    margin-top:12px;
  }
  .fuel-detail-row {
    display:flex;
    justify-content:space-between;
    font-size:0.78rem;
    padding:6px 0;
    border-top:1px solid var(--border);
    margin-top:8px;
  }
  .fuel-detail-row span:last-child {
    font-family:'Space Mono',monospace;
    color:var(--orange);
  }

  /* VS Chart */
  .vs-wrap { }
  .vs-bars {
    display:flex;
    gap:12px;
    align-items:flex-end;
    height:140px;
    margin-bottom:12px;
    padding-bottom:8px;
    border-bottom:1px solid var(--border);
  }
  .vs-col { flex:1;display:flex;flex-direction:column;align-items:center;gap:6px; }
  .vs-bar {
    width:100%;
    border-radius:6px 6px 0 0;
    transition: height 1s ease;
    position:relative;
    min-height:10px;
  }
  .vs-bar-label {
    font-family:'Orbitron',monospace;
    font-size:0.65rem;
    color:var(--muted);
    text-align:center;
    letter-spacing:1px;
  }
  .vs-bar-val {
    font-family:'Orbitron',monospace;
    font-size:0.8rem;
    font-weight:700;
    text-align:center;
  }

  .vs-legend {
    display:flex;
    gap:20px;
    flex-wrap:wrap;
  }
  .vs-legend-item {
    display:flex;
    align-items:center;
    gap:6px;
    font-size:0.75rem;
    color:var(--muted);
  }
  .vs-legend-dot { width:8px;height:8px;border-radius:2px; flex-shrink:0; }

  /* co2 avoided */
  .co2-row {
    display:flex;
    justify-content:space-between;
    align-items:center;
    background:rgba(0,255,136,0.04);
    border:1px solid rgba(0,255,136,0.1);
    border-radius:8px;
    padding:12px 16px;
    margin-top:12px;
    font-size:0.8rem;
  }
  .co2-val {
    font-family:'Orbitron',monospace;
    color:var(--green);
    font-size:1rem;
  }

  /* ===== REALTIME SPARKLINES ===== */
  .sparkline-grid {
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:16px;
    margin-bottom:24px;
  }
  .spark-card {
    background:var(--card);
    border:1px solid var(--border);
    border-radius:12px;
    padding:16px;
  }
  .spark-header {
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:10px;
  }
  .spark-name { font-size:0.8rem;font-weight:600; }
  .spark-now {
    font-family:'Orbitron',monospace;
    font-size:1rem;
    font-weight:700;
  }
  canvas.sparkline { width:100%;height:50px; }

  /* ===== RECOMMENDATION ===== */
  .rec-card {
    background: linear-gradient(135deg, rgba(255,228,77,0.05), rgba(0,255,136,0.03));
    border:1px solid rgba(255,228,77,0.2);
    border-radius:16px;
    padding:24px;
    margin-bottom:24px;
    display:flex;
    gap:20px;
    align-items:flex-start;
  }
  .rec-icon { font-size:2.5rem;flex-shrink:0; }
  .rec-title {
    font-family:'Orbitron',monospace;
    font-size:0.85rem;
    letter-spacing:3px;
    color:var(--yellow);
    margin-bottom:10px;
  }
  .rec-text { font-size:0.9rem;line-height:1.7;color:var(--text);opacity:0.85; }
  .rec-highlight { color:var(--green);font-weight:600; }

  /* ===== RESPONSIVE ===== */
  @media (max-width:1100px) {
    .top-stats { grid-template-columns:repeat(2,1fr); }
    .main-grid { grid-template-columns:1fr; }
    .compare-grid { grid-template-columns:1fr; }
    .bottom-grid { grid-template-columns:1fr; }
    .sparkline-grid { grid-template-columns:1fr; }
  }
  @media (max-width:600px) {
    header { padding:14px 16px; flex-wrap:wrap; gap:8px; }
    .logo { font-size:1.2rem; }
    .container { padding:16px 12px; }
    .top-stats { grid-template-columns:1fr 1fr; }
    .stat-value { font-size:1.5rem; }
  }

  /* Animate on load */
  @keyframes fadeUp {
    from{opacity:0;transform:translateY(20px);}
    to{opacity:1;transform:translateY(0);}
  }
  .animate { animation: fadeUp 0.6s ease forwards; opacity:0; }
  .d1{animation-delay:0.1s}.d2{animation-delay:0.2s}.d3{animation-delay:0.3s}
  .d4{animation-delay:0.4s}.d5{animation-delay:0.5s}.d6{animation-delay:0.6s}

  /* Number counter animation */
  .counting { animation: countPop 0.3s ease; }
  @keyframes countPop {
    0%{transform:scale(1.2);} 100%{transform:scale(1);}
  }
</style>
</head>
<body>

<div class="orb orb1"></div>
<div class="orb orb2"></div>
<div class="orb orb3"></div>

<!-- HEADER -->
<header>
  <div class="logo">ECO<span>GRID</span></div>
  <div class="live-badge"><div class="live-dot"></div>LIVE MONITORING</div>
  <div class="clock" id="clock">--:--:--</div>
</header>

<div class="container">

  <!-- TOP STATS -->
  <div class="section-title animate d1">Today's Summary</div>
  <div class="top-stats animate d2">
    <div class="stat-card" style="--accent:var(--green)">
      <div class="stat-icon">⚡</div>
      <div class="stat-label">Total Renewable Today</div>
      <div class="stat-value" id="totalKwh">0<span class="stat-unit">kWh</span></div>
      <div class="stat-sub" id="totalTrend">↑ 12% vs yesterday</div>
    </div>
    <div class="stat-card" style="--accent:var(--yellow)">
      <div class="stat-icon">🏆</div>
      <div class="stat-label">Top Producer</div>
      <div class="stat-value" id="topProducer" style="font-size:1rem;margin-top:6px;">—</div>
      <div class="stat-sub" id="topPct">—</div>
    </div>
    <div class="stat-card" style="--accent:var(--orange)">
      <div class="stat-icon">⛽</div>
      <div class="stat-label">Fuel Saved Today</div>
      <div class="stat-value" id="fuelSavedTop">0<span class="stat-unit">L</span></div>
      <div class="stat-sub">diesel equivalent avoided</div>
    </div>
    <div class="stat-card" style="--accent:var(--blue)">
      <div class="stat-icon">🌿</div>
      <div class="stat-label">CO₂ Avoided</div>
      <div class="stat-value" id="co2Avoided">0<span class="stat-unit">kg</span></div>
      <div class="stat-sub">carbon emissions saved</div>
    </div>
  </div>

  <!-- MAIN GRID: Sources + Donut -->
  <div class="main-grid animate d3">
    <!-- Source breakdown -->
    <div class="card">
      <div class="card-title">⚡ Energy Generation by Source</div>
      <div class="source-list">
        <!-- Windmill -->
        <div class="source-item">
          <div class="source-header">
            <div class="source-name">
              <span class="source-icon">🌬️</span>
              Large Windmill
              <span class="winner-badge" id="windmillBadge" style="display:none">⭐ Top Today</span>
            </div>
            <div class="source-kwh" style="color:var(--blue)" id="windmillKwh">0 kWh</div>
          </div>
          <div class="bar-track">
            <div class="bar-fill" id="windmillBar" style="background:linear-gradient(90deg,#00cfff,#007aff);width:0%"></div>
          </div>
          <div class="source-pct" id="windmillPct">0% of total</div>
        </div>
        <!-- Wind Spindle -->
        <div class="source-item">
          <div class="source-header">
            <div class="source-name">
              <span class="source-icon">💨</span>
              Wind Spindle
              <span class="winner-badge" id="spindleBadge" style="display:none">⭐ Top Today</span>
            </div>
            <div class="source-kwh" style="color:var(--green)" id="spindleKwh">0 kWh</div>
          </div>
          <div class="bar-track">
            <div class="bar-fill" id="spindleBar" style="background:linear-gradient(90deg,#00ff88,#00cc6a);width:0%"></div>
          </div>
          <div class="source-pct" id="spindlePct">0% of total</div>
        </div>
        <!-- Solar -->
        <div class="source-item">
          <div class="source-header">
            <div class="source-name">
              <span class="source-icon">☀️</span>
              Solar Panels
              <span class="winner-badge" id="solarBadge" style="display:none">⭐ Top Today</span>
            </div>
            <div class="source-kwh" style="color:var(--yellow)" id="solarKwh">0 kWh</div>
          </div>
          <div class="bar-track">
            <div class="bar-fill" id="solarBar" style="background:linear-gradient(90deg,#ffe44d,#ffaa00);width:0%"></div>
          </div>
          <div class="source-pct" id="solarPct">0% of total</div>
        </div>
      </div>
    </div>

    <!-- Donut -->
    <div class="card">
      <div class="card-title">📊 Share Distribution</div>
      <div class="donut-wrap">
        <svg class="donut-svg" width="160" height="160" viewBox="0 0 160 160" id="donutSvg">
          <circle cx="80" cy="80" r="60" fill="none" stroke="#0b2318" stroke-width="28"/>
          <!-- Windmill arc -->
          <circle id="arcWindmill" cx="80" cy="80" r="60" fill="none" stroke="#00cfff" stroke-width="28"
            stroke-dasharray="0 377" stroke-dashoffset="94" stroke-linecap="butt"
            style="transition:stroke-dasharray 1.2s ease;transform:rotate(-90deg);transform-origin:80px 80px"/>
          <!-- Spindle arc -->
          <circle id="arcSpindle" cx="80" cy="80" r="60" fill="none" stroke="#00ff88" stroke-width="28"
            stroke-dasharray="0 377" stroke-dashoffset="94" stroke-linecap="butt"
            style="transition:stroke-dasharray 1.2s ease,stroke-dashoffset 1.2s ease;transform:rotate(-90deg);transform-origin:80px 80px"/>
          <!-- Solar arc -->
          <circle id="arcSolar" cx="80" cy="80" r="60" fill="none" stroke="#ffe44d" stroke-width="28"
            stroke-dasharray="0 377" stroke-dashoffset="94" stroke-linecap="butt"
            style="transition:stroke-dasharray 1.2s ease,stroke-dashoffset 1.2s ease;transform:rotate(-90deg);transform-origin:80px 80px"/>
          <!-- Center text -->
          <text x="80" y="74" text-anchor="middle" fill="#00ff88" font-family="Orbitron" font-size="18" font-weight="700" id="donutCenter">—</text>
          <text x="80" y="92" text-anchor="middle" fill="#4a8a6a" font-family="Space Mono" font-size="9">kWh TODAY</text>
        </svg>
        <div class="donut-legend">
          <div class="legend-item">
